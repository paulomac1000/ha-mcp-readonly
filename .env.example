# Home Assistant connection
HA_URL=http://homeassistant:8123
HA_TOKEN=your_long_lived_access_token_here
HA_CONFIG_PATH=/config

# Server ports (defaults shown)
HEALTH_CHECK_PORT=9091
MCP_SSE_PORT=9092
REST_API_PORT=9093

# Feature flags
MCP_DEV_TOOLS_ENABLED=1
RUN_TESTS_ON_STARTUP=0

# Health reporter (disabled by default — set to 1 to enable)
HEALTH_REPORT_ENABLED=0

# Context generator output path
OUTPUT_PATH=/app/output/ha-ai-context.md
