# ==============================================================================
# Home Assistant MCP Readonly Server — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Home Assistant Connection (REQUIRED for smoke/e2e tests)
# ------------------------------------------------------------------------------
# Create a long-lived access token in HA:
#   Settings → Security → Long-Lived Access Tokens
HA_URL=http://localhost:8123
HA_TOKEN=your_long_lived_access_token_here

# ------------------------------------------------------------------------------
# Optional — override default paths and ports
# ------------------------------------------------------------------------------
# HA_CONFIG_PATH=/config
# HEALTH_CHECK_PORT=9091
# MCP_SSE_PORT=9092
# REST_API_PORT=9093

# ------------------------------------------------------------------------------
# Optional — server feature flags
# ------------------------------------------------------------------------------
# Enable template testing and dev tools (default: 1)
# MCP_DEV_TOOLS_ENABLED=1
# Run unit tests on container startup (default: 0)
# RUN_TESTS_ON_STARTUP=0

# ------------------------------------------------------------------------------
# Optional — health reporter schedule
# ------------------------------------------------------------------------------
# HEALTH_REPORT_ENABLED=0
# HEALTH_REPORT_AT=06:00
# HEALTH_REPORT_TZ=Europe/Warsaw
# HEALTH_REPORT_JITTER_SEC=300

# ------------------------------------------------------------------------------
# Optional — context generator output
# ------------------------------------------------------------------------------
# OUTPUT_PATH=/app/output/ha-ai-context.md
